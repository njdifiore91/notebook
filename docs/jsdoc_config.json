{
  "markdown": {
    "parser": "gfm"
  },
  "plugins": ["plugins/markdown", "jsdoc_plugin.js"],
  "source": {
    "include": [
      "../notebook/static/notebook/js/notebook.js",
      "../packages/notebook/src/collab/*.ts",
      "../packages/notebook-extension/src/components/*.tsx"
    ]
  },
  "tags": {
    "allowUnknownTags": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}